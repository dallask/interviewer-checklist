{
  "manifest_version": 3,
  "name": "Interviewer Checklist",
  "version": "1.0.0",
  "description": "Weighted tech-stack interview scoring, notes, and YAML export — fully local.",
  "icons": {
    "16": "public/icons/icon-16.png",
    "32": "public/icons/icon-32.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },
  "action": {
    "default_title": "Open Interviewer Checklist",
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "32": "public/icons/icon-32.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+I",
        "mac": "Command+Shift+I"
      },
      "description": "Open Interviewer Checklist"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": ["storage"],
  "minimum_chrome_version": "116",
  "web_accessible_resources": [
    {
      "resources": ["src/app/welcome.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
